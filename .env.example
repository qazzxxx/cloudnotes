# ─────────────────────────────────────────────────────────────
# 云简 (CloudNote) — 环境变量样例
# 复制为 .env 并按需修改。docker-compose 会自动读取同目录的 .env
# ─────────────────────────────────────────────────────────────

# 笔记根目录 (Root Space)：所有 .md 与 assets 都存放在此绝对/相对路径下。
# - 本地开发：指向一个本地可写目录（默认 ./notes，即项目根下）
# - Docker：docker-compose 会强制覆盖为容器内 /data/notes，此项不生效
ROOT_SPACE=./notes

# 服务端口
PORT=3130

# ── 鉴权 ───────────────────────────────────────────────────
# NAS 私人密码。留空 / 不设置 = 开放模式（不校验，适合内网无密码访问）。
# 生产强烈建议设置一个强密码。
NAS_PASSWORD=

# JWT 签名密钥。生产请务必替换为一段长随机串。
# 留空时后端会在启动时自动生成一个临时随机密钥（重启后已下发的 token 失效）。
JWT_SECRET=

# JWT 有效期（小时），默认 72
JWT_EXPIRES_HOURS=72

# 是否允许跨域（开发时 Vite 默认在 5173，后端在 3130，需要 CORS）
CORS_ORIGIN=

# ── Docker / docker-compose ───────────────────────────────
# 宿主机上的笔记目录（直接挂载进容器 /data/notes）。建议指向你的 NAS 共享路径。
ROOT_SPACE_HOST=./notes

# 宿主机映射端口（容器内固定 3130）
PORT_HOST=3130

# ── BlockNote AI（可选，OpenAI 兼容）─────────────────────
# 三者都配置才会启用编辑器内的 AI 功能（选中文本 AI 按钮、/ai 命令等）；
# 留空则编辑器与无 AI 时完全一致。Key 仅存服务端，不会暴露给前端。
#
# 常见 AI_BASE_URL：
#   OpenAI    https://api.openai.com/v1
#   DeepSeek  https://api.deepseek.com/v1
#   MiniMax   https://api.minimaxi.com/v1        （注意用 /v1 即 OpenAI 兼容端点，不要用 /anthropic）
#   本地 Ollama http://<nas-ip>:11434/v1   （Key 随意填，模型如 qwen2.5）
AI_BASE_URL=
AI_API_KEY=
# 模型名示例：gpt-4o-mini / deepseek-chat / qwen2.5
AI_MODEL=
