{
  "name": "@cloudnote/extension",
  "version": "0.0.6",
  "private": true,
  "description": "云简 CloudNote 浏览器剪藏扩展 —— 把网页标题/正文/图片一键存进云简",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.0.287",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
